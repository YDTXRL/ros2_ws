# ===================== ROS 2 工作空间通用忽略项 =====================
# 1. colcon 编译生成的目录（核心！无需提交）
build/
install/
log/

# 2. Python 相关临时文件
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
pip-wheel-metadata/

# 3. C++ 编译临时文件
*.o
*.lo
*.la
*.al
*.libs
*.so
*.so.[0-9]*
*.a
*.pyc
*.obj
*.swp
*.swo
.DS_Store

# 4. ROS 2 运行时临时文件
*.log
*.bag
*.db
*.sqlite3
ros2*_pid*
*.tmp
*.temp

# 5. 编辑器/IDE 配置文件（根据自己使用的工具添加）
# VS Code
.vscode/
# Vim
*.swp
*.swo
# JetBrains (CLion/PyCharm)
.idea/
*.iml
# Eclipse
.project
.cproject
.settings/

# 6. 系统临时文件
.DS_Store       # MacOS
Thumbs.db       # Windows
*.bak
*.backup
*.orig
*.rej

# 7. 虚拟环境/容器相关
venv/
env/
.dockerignore
.dockerfile
